{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist-server",
    "rootDir": "."
  },
  "include": [
    "server/**/*.ts",
    "shared/**/*.ts"
  ]
}
