# =============================================================================
# Shot Caller VR — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
# Do not commit .env — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Pipeline: Google Street View
# -----------------------------------------------------------------------------
# Required for Street View API. Enable "Street View Static API" in Google Cloud.
# https://console.cloud.google.com/apis/library/street-view-image-backend.googleapis.com
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Pipeline: Nano Banana 2.5 (Image Expansion)
# -----------------------------------------------------------------------------
# Choose one provider:

# Replicate — get token at replicate.com/account
# Model: https://replicate.com/google/nano-banana-2
REPLICATE_API_TOKEN=

# Or Google AI Studio / Vertex AI
# GOOGLE_AI_API_KEY=
