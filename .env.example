# =============================================================================
# Shot Caller VR — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
# Do not commit .env — it is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Pipeline: Google Street View
# -----------------------------------------------------------------------------
# Required for the Scout map and Street View tooling in the Vite client.
# This must use the Vite-exposed variable name because the browser bundle reads
# import.meta.env.VITE_GOOGLE_MAPS_API_KEY.
#
# In Google Cloud, enable:
# - Maps JavaScript API
# - Places API
# - Street View Static API
#
# If you see ApiTargetBlockedMapError on local dev, verify the key's HTTP
# referrer restrictions include your dev origin, for example:
# - https://localhost:8081/*
# - http://localhost:8081/*
#
# API library links:
# https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
# https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# https://console.cloud.google.com/apis/library/street-view-image-backend.googleapis.com
VITE_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Pipeline: Marble Labs (Gaussian Splat Generation)
# -----------------------------------------------------------------------------
# Required to submit Street View images and receive a .spz Gaussian splat.
MARBLE_LABS_API_KEY=

# -----------------------------------------------------------------------------
# Mastra Intake Layer
# -----------------------------------------------------------------------------
# The intake backend defaults to OpenRouter-routed model IDs. If you keep the
# default models below, set your OpenRouter key.
OPENROUTER_API_KEY=test

# Optional overrides for the local intake runtime
SHOT_CALLER_SERVER_PORT=8787
SHOT_CALLER_INTAKE_MODEL=openrouter/openai/gpt-4.1-mini
SHOT_CALLER_IMAGE_PROMPT_MODEL=openrouter/openai/gpt-4.1-mini
SHOT_CALLER_MESHY_PROMPT_MODEL=openrouter/openai/gpt-4.1-mini
