{
  "name": "sensai-webxr-worldmodels",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,server \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "test": "node --import tsx --test test/**/*.test.ts",
    "intake:list-threads": "tsx server/scripts/list-intake-threads.ts",
    "intake:delete-thread": "tsx server/scripts/delete-intake-thread.ts",
    "pipeline:fetch": "tsx pipeline/scripts/fetch-street-view.ts",
    "pipeline:expand": "tsx pipeline/scripts/expand-images.ts",
    "pipeline:output": "tsx pipeline/scripts/prepare-output.ts",
    "pipeline:generate": "tsx pipeline/scripts/generate-splat.ts",
    "pipeline:run": "tsx pipeline/scripts/run-pipeline.ts"
  },
  "dependencies": {
    "@iwsdk/core": "0.2.2",
    "@libsql/client": "^0.17.0",
    "@mastra/core": "^1.13.2",
    "@mastra/libsql": "^1.7.0",
    "@mastra/memory": "^1.8.2",
    "@sparkjsdev/spark": "github:sparkjsdev/spark#v2.0.0-preview",
    "express": "^5.2.1",
    "image-size": "^2.0.2",
    "multer": "^2.1.1",
    "replicate": "^0.34.0",
    "three": "npm:super-three@0.181.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@iwsdk/vite-plugin-gltf-optimizer": "0.2.2",
    "@iwsdk/vite-plugin-iwer": "0.2.2",
    "@iwsdk/vite-plugin-uikitml": "0.2.2",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/three": "^0.181.0",
    "concurrently": "^9.2.1",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0",
    "vite": "^7.1.4",
    "vite-plugin-mkcert": "^1.17.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
